rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.isAdmin == true;
    }

    // Entitlements / admin — only Admin SDK or an existing isAdmin client.
    function privilegedCreateOk() {
      let d = request.resource.data;
      return (!('hasKit' in d) || d.hasKit == false)
        && (!('hasPremium' in d) || d.hasPremium == false)
        && (!('hasPostres' in d) || d.hasPostres == false)
        && (!('hasPostresPremium' in d) || d.hasPostresPremium == false)
        && (!('hasMinipostres' in d) || d.hasMinipostres == false)
        && (!('hasMinipostresPremium' in d) || d.hasMinipostresPremium == false)
        && (!('isAdmin' in d) || d.isAdmin == false);
    }

function privilegedUnchanged() {
      return request.resource.data.get('hasKit', false) == resource.data.get('hasKit', false)
        && request.resource.data.get('hasPremium', false) == resource.data.get('hasPremium', false)
        && request.resource.data.get('hasPostres', false) == resource.data.get('hasPostres', false)
        && request.resource.data.get('hasPostresPremium', false) == resource.data.get('hasPostresPremium', false)
        && request.resource.data.get('hasMinipostres', false) == resource.data.get('hasMinipostres', false)
        && request.resource.data.get('hasMinipostresPremium', false) == resource.data.get('hasMinipostresPremium', false)
        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false);
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId) && privilegedCreateOk();
      allow update: if isAdmin() || (isSelf(userId) && privilegedUnchanged());
      allow delete: if isAdmin();

      match /scenarios/{scenarioId} {
        allow read, write: if isSelf(userId);
      }

      match /private/{docId} {
        allow read, write: if isSelf(userId);
      }
    }

    // Codes validated server-side (/api/redeem-access-code). Clients never list/guess.
    match /accessCodes/{codeId} {
      allow read, write: if isAdmin();
    }

    match /menus/{slug} {
      allow read: if resource.data.published == true
        || (signedIn() && resource.data.ownerUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll([
          'ownerUid', 'published', 'businessName', 'whatsapp', 'items', 'note', 'updatedAt', 'createdAt'
        ])
        && request.resource.data.businessName is string
        && request.resource.data.whatsapp is string
        && request.resource.data.items is list
        && request.resource.data.note is string
        && request.resource.data.published is bool
        && (!('categories' in request.resource.data) || request.resource.data.categories is list)
        && (!('tagline' in request.resource.data) || request.resource.data.tagline is string)
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('coverImage' in request.resource.data) || request.resource.data.coverImage is string)
        && (!('logoImage' in request.resource.data) || request.resource.data.logoImage is string);

      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Server-only (Admin SDK). Clients must use /api/claim-pending.
    match /pending_purchases/{email} {
      allow read, write: if false;
    }

    match /purchase_webhook_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Server-only (Admin SDK via /api/diagnostico/lead and /api/admin/diagnostico-leads).
    match /diagnostico_leads/{leadId} {
      allow read, write: if false;
    }

    // Server-only — Hotmart transaction dedupe (Admin SDK).
    match /purchase_transactions/{txId} {
      allow read, write: if false;
    }
  }
}
