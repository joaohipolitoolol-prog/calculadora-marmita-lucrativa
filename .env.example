# Firebase — projeto: paletas-whatsapp-kit
# Console: https://console.firebase.google.com/project/paletas-whatsapp-kit

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=paletas-whatsapp-kit.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=paletas-whatsapp-kit
VITE_FIREBASE_STORAGE_BUCKET=paletas-whatsapp-kit.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=990964023431
VITE_FIREBASE_APP_ID=

# Emails com acesso admin (separados por vírgula). Após alterar na Vercel, faça redeploy.
# Também pode gerenciar em /admin → Contenido (salva no Firestore sem redeploy).
VITE_ADMIN_EMAILS=seu@email.com

# Link de checkout (Hotmart, Kiwify, etc.)
VITE_CHECKOUT_URL=

# --- Mini Postres Fríos Sin Horno (/minipostres) ---
# Vite también acepta el prefijo NEXT_PUBLIC_ (ver envPrefix en vite.config.js)
NEXT_PUBLIC_MINIPOSTRES_PRICE=7.49
NEXT_PUBLIC_MINIPOSTRES_CHECKOUT_URL=https://pay.hotmart.com/COLOCAR_LINK_MINIPOSTRES?checkoutMode=10
NEXT_PUBLIC_MINIPOSTRES_VSL_URL=
NEXT_PUBLIC_MINIPOSTRES_BUMP_MESSAGES_PRICE=2.90
NEXT_PUBLIC_MINIPOSTRES_BUMP_CATALOG_PRICE=2.90
NEXT_PUBLIC_MINIPOSTRES_ACCESS_URL=/app?line=minipostres
# NEXT_PUBLIC_MINIPOSTRES_SUPPORT_URL=

# --- Dev local ---
# Proxy das APIs /api para produção durante npm run dev (padrão: paletasparawhatsapp.vercel.app)
# VITE_DEV_API_URL=https://paletasparawhatsapp.vercel.app

# Para APIs locais com variáveis de servidor: npm run dev:api (requer Vercel CLI)

# Resend: https://resend.com/api-keys
RESEND_API_KEY=
# Domínio verificado no Resend, ex: Paletas <acceso@seudominio.com>
RESEND_FROM_EMAIL=Paletas para WhatsApp <onboarding@resend.dev>

# URL canônica do site (emails e links)
SITE_URL=https://paletasparawhatsapp.vercel.app

# Hotmart webhook — Tools → Webhook → hottok
# Endpoint: POST /api/webhooks/hotmart
HOTMART_HOTTOK=
# Opcional: JSON map se os IDs no dashboard forem diferentes dos checkout codes
# HOTMART_PRODUCT_MAP={"123456":"paletas_kit","789012":"postres_kit"}

# Webhook genérico (testes / n8n) — Bearer token
# Endpoint: POST /api/webhooks/purchase
PURCHASE_WEBHOOK_SECRET=

# Firebase Admin — JSON da service account em uma linha
# Firebase Console → Project settings → Service accounts → Generate new private key
# Obrigatório na Vercel para: /api/admin/*, webhooks, e salvar A/B pelo painel
FIREBASE_SERVICE_ACCOUNT=

# Opcional no servidor (além de VITE_ADMIN_EMAILS no build)
# ADMIN_EMAILS=seu@email.com

# Código de acesso fallback (somente servidor — NUNCA VITE_*). Prefira códigos no /admin.
# ACCESS_CODE=
# ACCESS_CODE_TYPE=kit

# Meta Conversions API — Purchase via webhook Hotmart (OFF by default).
# Do NOT enable until Hotmart → Ferramentas → Pixel de Rastreamento → Facebook
# has ZERO Purchase event on your Pixel ID (Hotmart fires Purchase on checkout
# itself and that is the #1 fake-sale source).
# META_CAPI_PURCHASE_ENABLED=1
# META_CAPI_ACCESS_TOKEN=
# META_PIXEL_ID=1369803401885896

# Google Cloud Text-to-Speech (modo audio guiado nas receitas)
# Console: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Importante: restrinja a chave para "Cloud Text-to-Speech API" e use "Nenhuma" em
# restrição de aplicativo (serverless na Vercel não envia referrer do browser).
GOOGLE_TTS_API_KEY=
