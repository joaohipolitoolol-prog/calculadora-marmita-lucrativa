{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/diagnostico", "destination": "/diagnostico.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/cadastrar", "destination": "/cadastrar.html" },
    { "source": "/postres/login", "destination": "/login-postres.html" },
    { "source": "/postres/cadastrar", "destination": "/cadastrar-postres.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/membros", "destination": "/membros.html" },
    { "source": "/paletas-de-whatsapp", "destination": "/membros.html" },
    { "source": "/paletas-de-whatsapp/entrega.html", "destination": "/membros.html" },
    { "source": "/paletas-premium", "destination": "/membros.html" },
    { "source": "/acesso", "destination": "/acesso.html" },
    { "source": "/upsell-paletas-premium", "destination": "/upsell-paletas-premium.html" },
    { "source": "/postres", "destination": "/postres.html" },
    { "source": "/postres/upsell", "destination": "/postres-upsell.html" },
    { "source": "/upsell-postres-premium", "destination": "/postres-upsell.html" },
    { "source": "/postresaviso", "destination": "/postres-aviso.html" },
    { "source": "/postres/entrega", "destination": "/postres/entrega.html" },
    { "source": "/postres-premium/entrega", "destination": "/postres-premium/entrega.html" },
    { "source": "/m/:slug", "destination": "/m.html" }
  ],
  "redirects": [
    {
      "source": "/minipostres",
      "destination": "/postres",
      "permanent": true
    },
    {
      "source": "/minipostres/gracias",
      "destination": "/postresaviso",
      "permanent": true
    },
    {
      "source": "/cadastrar",
      "has": [{ "type": "query", "key": "line", "value": "postres" }],
      "destination": "/postres/cadastrar",
      "permanent": false
    },
    {
      "source": "/login",
      "has": [{ "type": "query", "key": "line", "value": "postres" }],
      "destination": "/postres/login",
      "permanent": false
    }
  ]
}
